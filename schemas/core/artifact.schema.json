{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "core/artifact.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "record_type", "id", "name", "artifact_type", "status", "source_ids", "taxonomy_node_ids"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "record_type": { "const": "artifact" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "artifact_type": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "source_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "taxonomy_node_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "population_or_context": { "type": "string" },
    "sample_size": { "type": ["integer", "string"] },
    "methods": { "type": "string" },
    "endpoint_categories": { "type": "array", "items": { "type": "string" } },
    "numeric_results_extracted": {
      "anyOf": [{ "type": "boolean" }, { "const": "not_applicable" }]
    }
  }
}
