{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "core/domain.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "name",
    "summary",
    "taxonomy_file",
    "evidence_ladder_file",
    "review_lanes_file",
    "public_copy_file",
    "default_scope_unit",
    "default_review_lanes"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "taxonomy_file": { "type": "string", "minLength": 1 },
    "evidence_ladder_file": { "type": "string", "minLength": 1 },
    "review_lanes_file": { "type": "string", "minLength": 1 },
    "public_copy_file": { "type": "string", "minLength": 1 },
    "default_scope_unit": { "type": "string", "minLength": 1 },
    "default_review_lanes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "planning": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "stale_after_days": { "type": "integer", "minimum": 1 }
      }
    },
    "source_access_policy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "minimum_finding_access_depth": {
          "enum": ["full_text", "abstract_only", "metadata_only", "not_checked", "unavailable"]
        },
        "insufficient_finding_access_action": {
          "enum": ["ignore", "warn", "block_publication"]
        },
        "follow_up_priority": {
          "enum": ["low", "medium", "high"]
        },
        "enforce_inferred_access_depth": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "applicability_facets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "label", "applies_to"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "applies_to": {
            "type": "array",
            "items": { "enum": ["artifact", "finding", "claim", "search_protocol"] },
            "minItems": 1,
            "uniqueItems": true
          },
          "values": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["id", "label"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "label": { "type": "string", "minLength": 1 },
                "description": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
