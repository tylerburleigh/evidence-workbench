{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "core/finding.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "record_type",
    "id",
    "name",
    "source_id",
    "taxonomy_node_ids",
    "endpoint_category",
    "direction",
    "evidence_tier",
    "confidence",
    "statement"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "record_type": { "const": "finding" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "source_id": { "type": "string", "minLength": 1 },
    "artifact_id": { "type": "string" },
    "taxonomy_node_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "endpoint_category": { "type": "string", "minLength": 1 },
    "direction": { "type": "string", "minLength": 1 },
    "evidence_tier": { "type": "string", "minLength": 1 },
    "confidence": { "type": "string", "minLength": 1 },
    "statement": { "type": "string", "minLength": 1 },
    "population_or_context": { "type": "string" },
    "time_horizon": { "type": "string" },
    "quantitative_note": { "type": "string" },
    "source_locator": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "additionalProperties": true,
          "required": ["verification_status"],
          "properties": {
            "section": { "type": "string" },
            "page": { "type": ["string", "integer"] },
            "table": { "type": "string" },
            "appendix": { "type": "string" },
            "url": { "type": "string" },
            "quote_or_paraphrase_note": { "type": "string" },
            "verification_status": {
              "enum": ["unverified", "located", "verified"]
            }
          }
        }
      ]
    },
    "caveats": { "type": "array", "items": { "type": "string" } },
    "numeric_results_extracted": {
      "anyOf": [{ "type": "boolean" }, { "const": "not_applicable" }]
    }
  }
}
