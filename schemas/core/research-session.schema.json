{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "core/research-session.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "record_type", "id", "mode", "started_at", "completed_at", "scope", "outcome", "summary"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "record_type": { "const": "research_session" },
    "id": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["bootstrap", "surveillance", "manual"] },
    "started_at": { "type": "string", "minLength": 1 },
    "completed_at": { "type": "string", "minLength": 1 },
    "scope": { "type": "object" },
    "selected_via": { "type": "string" },
    "outcome": { "enum": ["candidate_bundle", "no_op", "activity_only", "blocked"] },
    "summary": { "type": "string", "minLength": 1 },
    "candidate_bundle_id": { "type": "string" },
    "source_ids": { "type": "array", "items": { "type": "string" } },
    "source_urls": { "type": "array", "items": { "type": "string" } },
    "next_recommended_mode": { "enum": ["bootstrap", "surveillance", "manual"] },
    "next_actions": { "type": "array", "items": { "type": "string" } }
  }
}
