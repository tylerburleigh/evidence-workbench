{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "core/candidate-bundle.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "record_type",
    "id",
    "name",
    "intake_mode",
    "lifecycle_status",
    "submitted_at",
    "submitted_by",
    "revision_number",
    "scope",
    "proposed_changes",
    "required_appraisal_lanes",
    "appraisal_requirement"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "record_type": { "const": "candidate_bundle" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "intake_mode": { "enum": ["baseline_review", "review_update", "manual"] },
    "lifecycle_status": {
      "enum": ["submitted", "in_review", "needs_revision", "revised", "approved", "published", "rejected"]
    },
    "submitted_at": { "type": "string", "minLength": 1 },
    "submitted_by": { "type": "string", "minLength": 1 },
    "revision_number": { "type": "integer", "minimum": 1 },
    "scope": { "type": "object" },
    "source_ids": { "type": "array", "items": { "type": "string" } },
    "source_urls": { "type": "array", "items": { "type": "string" } },
    "related_records": { "type": "array", "items": { "type": "object" } },
    "proposed_changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["change_id", "change_type", "target_record_type", "target_record_id", "summary", "rationale"],
        "properties": {
          "change_id": { "type": "string", "minLength": 1 },
          "change_type": { "enum": ["create_record", "update_record"] },
          "target_record_type": { "enum": ["source", "artifact", "finding", "claim", "activity_item", "search_protocol"] },
          "target_record_id": { "type": "string", "minLength": 1 },
          "file_path": { "type": "string" },
          "staged_file_path": { "type": "string" },
          "summary": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 }
        }
      }
    },
    "proposed_claim_implications": { "type": "array", "items": { "type": "object" } },
    "required_appraisal_lanes": { "type": "array", "items": { "type": "string" } },
    "appraisal_requirement": { "type": "object" },
    "evidence_appraisal_ids": { "type": "array", "items": { "type": "string" } },
    "editorial_comment_ids": { "type": "array", "items": { "type": "string" } },
    "publication_event_ids": { "type": "array", "items": { "type": "string" } },
    "next_actions": { "type": "array", "items": { "type": "string" } },
    "source_access_follow_up_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/source_access_follow_up_action" }
    },
    "extraction_follow_up_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/extraction_follow_up_action" }
    }
  },
  "$defs": {
    "extraction_follow_up_action": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "action_id",
        "action_type",
        "status",
        "priority",
        "target_record_type",
        "target_record_id",
        "source_ids",
        "reason",
        "recommended_action"
      ],
      "properties": {
        "action_id": { "type": "string", "minLength": 1 },
        "action_type": { "const": "numeric_results_extraction" },
        "status": { "enum": ["open", "addressed", "closed"] },
        "priority": { "enum": ["low", "medium", "high"] },
        "target_record_type": { "enum": ["artifact", "finding"] },
        "target_record_id": { "type": "string", "minLength": 1 },
        "source_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "taxonomy_node_ids": { "type": "array", "items": { "type": "string" } },
        "metric_fields_present": { "type": "array", "items": { "type": "string" } },
        "artifact_id": { "type": "string" },
        "finding_id": { "type": "string" },
        "reason": { "type": "string", "minLength": 1 },
        "recommended_action": { "type": "string", "minLength": 1 }
      }
    },
    "source_access_follow_up_action": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "action_id",
        "action_type",
        "status",
        "priority",
        "target_record_type",
        "target_record_id",
        "source_ids",
        "reason",
        "recommended_action"
      ],
      "properties": {
        "action_id": { "type": "string", "minLength": 1 },
        "action_type": { "const": "source_access_resolution" },
        "status": { "enum": ["open", "addressed", "closed"] },
        "priority": { "enum": ["low", "medium", "high"] },
        "target_record_type": { "enum": ["source", "finding", "claim"] },
        "target_record_id": { "type": "string", "minLength": 1 },
        "source_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "taxonomy_node_ids": { "type": "array", "items": { "type": "string" } },
        "access_status": { "type": "string" },
        "access_depth": { "type": "string" },
        "locator_depth": { "type": "string" },
        "required_access_depth": { "type": "string" },
        "finding_id": { "type": "string" },
        "artifact_id": { "type": "string" },
        "reason": { "type": "string", "minLength": 1 },
        "recommended_action": { "type": "string", "minLength": 1 }
      }
    }
  }
}
