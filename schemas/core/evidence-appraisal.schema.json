{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "core/evidence-appraisal.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "record_type",
    "id",
    "name",
    "candidate_bundle_id",
    "bundle_revision_number",
    "appraisal_round",
    "appraisal_lane",
    "appraiser_kind",
    "status",
    "verdict",
    "blocking",
    "summary",
    "appraised_change_ids",
    "findings"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "record_type": { "const": "evidence_appraisal" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "candidate_bundle_id": { "type": "string", "minLength": 1 },
    "bundle_revision_number": { "type": "integer", "minimum": 1 },
    "appraisal_round": { "type": "integer", "minimum": 1 },
    "appraisal_lane": { "type": "string", "minLength": 1 },
    "appraiser_kind": { "enum": ["agent", "human"] },
    "appraiser_id": { "type": "string" },
    "skill_name": { "type": "string" },
    "status": { "enum": ["complete", "superseded"] },
    "verdict": { "enum": ["accept", "needs_revision", "reject", "needs_human_judgment"] },
    "blocking": { "type": "boolean" },
    "summary": { "type": "string", "minLength": 1 },
    "appraised_change_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["finding_id", "severity", "category", "claim_or_issue", "why_it_matters", "recommended_action", "resolution_status"],
        "properties": {
          "finding_id": { "type": "string", "minLength": 1 },
          "severity": { "enum": ["critical", "major", "minor", "note"] },
          "category": { "type": "string", "minLength": 1 },
          "claim_or_issue": { "type": "string", "minLength": 1 },
          "why_it_matters": { "type": "string", "minLength": 1 },
          "recommended_action": { "type": "string", "minLength": 1 },
          "resolution_status": { "enum": ["open", "addressed", "closed"] },
          "applies_to_change_id": { "type": "string" }
        }
      }
    },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" }
  }
}
