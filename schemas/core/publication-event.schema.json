{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "core/publication-event.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "record_type",
    "id",
    "name",
    "candidate_bundle_id",
    "event_type",
    "published_at",
    "published_by",
    "published_targets",
    "change_note"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "record_type": { "const": "publication_event" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "candidate_bundle_id": { "type": "string", "minLength": 1 },
    "event_type": { "enum": ["publish"] },
    "published_at": { "type": "string", "minLength": 1 },
    "published_by": { "type": "string", "minLength": 1 },
    "published_targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["record_type", "record_id", "action"],
        "properties": {
          "record_type": { "type": "string", "minLength": 1 },
          "record_id": { "type": "string", "minLength": 1 },
          "action": { "enum": ["created", "updated"] }
        }
      }
    },
    "affected_claim_ids": { "type": "array", "items": { "type": "string" } },
    "approving_evidence_appraisal_ids": { "type": "array", "items": { "type": "string" } },
    "appraisal_follow_up_actions": { "type": "array", "items": { "type": "string" } },
    "source_access_follow_up_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/source_access_follow_up_action" }
    },
    "extraction_follow_up_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/extraction_follow_up_action" }
    },
    "change_note": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "extraction_follow_up_action": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "action_id",
        "action_type",
        "status",
        "priority",
        "target_record_type",
        "target_record_id",
        "source_ids",
        "reason",
        "recommended_action"
      ],
      "properties": {
        "action_id": { "type": "string", "minLength": 1 },
        "action_type": { "const": "numeric_results_extraction" },
        "status": { "enum": ["open", "addressed", "closed"] },
        "priority": { "enum": ["low", "medium", "high"] },
        "target_record_type": { "enum": ["artifact", "finding"] },
        "target_record_id": { "type": "string", "minLength": 1 },
        "source_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "taxonomy_node_ids": { "type": "array", "items": { "type": "string" } },
        "metric_fields_present": { "type": "array", "items": { "type": "string" } },
        "artifact_id": { "type": "string" },
        "finding_id": { "type": "string" },
        "reason": { "type": "string", "minLength": 1 },
        "recommended_action": { "type": "string", "minLength": 1 }
      }
    },
    "source_access_follow_up_action": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "action_id",
        "action_type",
        "status",
        "priority",
        "target_record_type",
        "target_record_id",
        "source_ids",
        "reason",
        "recommended_action"
      ],
      "properties": {
        "action_id": { "type": "string", "minLength": 1 },
        "action_type": { "const": "source_access_resolution" },
        "status": { "enum": ["open", "addressed", "closed"] },
        "priority": { "enum": ["low", "medium", "high"] },
        "target_record_type": { "enum": ["source", "finding", "claim"] },
        "target_record_id": { "type": "string", "minLength": 1 },
        "source_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "taxonomy_node_ids": { "type": "array", "items": { "type": "string" } },
        "access_status": { "type": "string" },
        "access_depth": { "type": "string" },
        "locator_depth": { "type": "string" },
        "required_access_depth": { "type": "string" },
        "finding_id": { "type": "string" },
        "artifact_id": { "type": "string" },
        "reason": { "type": "string", "minLength": 1 },
        "recommended_action": { "type": "string", "minLength": 1 }
      }
    }
  }
}
