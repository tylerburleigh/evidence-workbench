{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "core/search-protocol.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "record_type",
    "id",
    "name",
    "domain_id",
    "taxonomy_node_ids",
    "status",
    "search_started_at",
    "search_completed_at",
    "search_queries",
    "screening_summary"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "record_type": { "const": "search_protocol" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "domain_id": { "type": "string", "minLength": 1 },
    "taxonomy_node_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "status": {
      "enum": ["draft", "searched", "screened", "included_sources_staged", "complete"]
    },
    "search_started_at": { "type": "string", "minLength": 1 },
    "search_completed_at": { "type": "string", "minLength": 1 },
    "databases": { "type": "array", "items": { "type": "string" } },
    "search_queries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["database", "query", "searched_at"],
        "properties": {
          "database": { "type": "string", "minLength": 1 },
          "query": { "type": "string", "minLength": 1 },
          "searched_at": { "type": "string", "minLength": 1 },
          "result_count": { "type": ["integer", "string"] },
          "url": { "type": "string" }
        }
      }
    },
    "inclusion_criteria": { "type": "array", "items": { "type": "string" } },
    "exclusion_criteria": { "type": "array", "items": { "type": "string" } },
    "dedupe_method": { "type": "string" },
    "screening_counts": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "records_identified": { "type": ["integer", "string"] },
        "records_screened": { "type": ["integer", "string"] },
        "full_text_reviewed": { "type": ["integer", "string"] },
        "sources_included": { "type": ["integer", "string"] }
      }
    },
    "screening_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["candidate_id", "title", "decision"],
        "properties": {
          "candidate_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "decision": {
            "enum": ["include", "exclude", "maybe", "duplicate", "not_relevant", "no_full_text"]
          },
          "reason": { "type": "string" },
          "source_id": { "type": "string" },
          "doi": { "type": "string" },
          "url": { "type": "string" }
        }
      }
    },
    "source_ids": { "type": "array", "items": { "type": "string" } },
    "screening_summary": { "type": "string", "minLength": 1 },
    "limitations": { "type": "array", "items": { "type": "string" } }
  }
}
