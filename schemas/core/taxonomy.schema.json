{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "core/taxonomy.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": ["taxonomy_id", "taxonomy_version", "domain_id", "nodes"],
  "properties": {
    "taxonomy_id": { "type": "string", "minLength": 1 },
    "taxonomy_version": { "type": "string", "minLength": 1 },
    "domain_id": { "type": "string", "minLength": 1 },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "name", "node_type", "canonical_order", "summary"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "node_type": { "type": "string", "minLength": 1 },
          "parent_id": { "type": "string" },
          "canonical_order": { "type": "integer", "minimum": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "search_aliases": {
            "type": "array",
            "items": { "type": "string" }
          },
          "example_entities": {
            "type": "array",
            "items": { "type": "string" }
          },
          "scope_notes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "retirement_status": { "type": "string" }
        }
      }
    }
  }
}
