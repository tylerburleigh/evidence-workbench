{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "core/source.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "record_type", "id", "name", "source_type"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "record_type": { "const": "source" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "source_type": { "type": "string", "minLength": 1 },
    "authors": { "type": "array", "items": { "type": "string" } },
    "venue": { "type": "string" },
    "year": { "type": "integer" },
    "published_on": { "type": "string" },
    "doi": { "type": "string" },
    "pmid": { "type": "string" },
    "registry_ids": { "type": "array", "items": { "type": "string" } },
    "urls": { "type": "array", "items": { "type": "string" } },
    "summary": { "type": "string" },
    "access_status": {
      "enum": [
        "full_text_verified",
        "full_text_available",
        "abstract_only_paywalled",
        "abstract_only_available",
        "metadata_only",
        "not_yet_checked",
        "unavailable"
      ]
    },
    "access_depth": {
      "enum": [
        "full_text",
        "abstract_only",
        "metadata_only",
        "not_checked",
        "unavailable"
      ]
    },
    "access_attempts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "attempted_at": { "type": "string" },
          "url": { "type": "string" },
          "result": { "type": "string", "minLength": 1 },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
